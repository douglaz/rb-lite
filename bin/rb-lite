#!/usr/bin/env bash
set -Eeuo pipefail

PROGRAM=${0##*/}
TIMEOUT_KILL_AFTER=5s
readonly TIMEOUT_KILL_AFTER
readonly EXIT_USAGE=2
readonly EXIT_ENV=3
readonly EXIT_IMPLEMENTER=10
readonly EXIT_REVIEW_PANEL=11
readonly EXIT_MAX_ROUNDS=12
readonly EXIT_CONSENSUS=13
readonly EXIT_INTERNAL=70

unexpected_error() {
  local rc=$? line=${BASH_LINENO[0]:-unknown}
  printf '%s: internal error: unexpected command failed with exit %s near line %s\n' "$PROGRAM" "$rc" "$line" >&2
  exit "$EXIT_INTERNAL"
}
trap unexpected_error ERR

# Scrub inherited Claude Code session/instance markers so a spawned `claude`
# implementer/reviewer starts a FRESH session. When rb-lite is driven by an agent
# that is itself a Claude Code session, the child would otherwise inherit that
# session's identity (CLAUDE_CODE_SESSION_ID, CLAUDECODE, ...) and collide with it:
# the parent session's stdio breaks while rb-lite waits on the child, rb-lite dies
# with no JSON summary, and the child is orphaned. Auth is deliberately preserved —
# CLAUDE_CONFIG_DIR / CLAUDE_CODE_OAUTH_TOKEN / ANTHROPIC_* are never touched, so the
# fresh session reuses the existing credentials. Only IDENTITY markers are scrubbed;
# behavior flags are kept — notably CLAUDE_CODE_RETRY_WATCHDOG, which lets claude wait
# out 429/529 capacity limits indefinitely (strip it via RB_LITE_SCRUB_ENV only if you
# want rb-lite's bounded retries to be the sole limiter). rb-lite's built-in claude
# commands explicitly set CLAUDE_CODE_MAX_OUTPUT_TOKENS=128000. Override the list with
# RB_LITE_SCRUB_ENV (space-separated names); set it empty to disable. Outside a
# Claude Code session these vars are unset, so this is a no-op.
read -r -a _rb_scrub_env <<<"${RB_LITE_SCRUB_ENV-CLAUDECODE CLAUDE_CODE_SESSION_ID CLAUDE_CODE_CHILD_SESSION CLAUDE_CODE_ENTRYPOINT CLAUDE_CODE_EXECPATH}"
if (( ${#_rb_scrub_env[@]} > 0 )); then
  unset -v "${_rb_scrub_env[@]}" 2>/dev/null || true
fi
unset -v _rb_scrub_env

DEFAULT_PROMPT=$'Read AGENTS.md if present. If review files are provided, address the findings\nin those reviews. Treat each finding as a hypothesis you may challenge, not an\norder. If a finding is a false positive, or is over-specification (it adds\nmechanism, hardening, config, or abstraction that no real correctness, security,\nor data-loss requirement needs), do NOT implement it. Instead record a brief\nreasoned rejection (the finding plus why) in a file named\nchallenges-round-$ROUND.md inside the run directory $RUN_DIR. Apply the\nover-specification test before adding anything: if you simply do not do it, does a\nreal correctness/security/data-loss problem break, or only an operational\ninconvenience? Make the smallest correct change that closes a real problem; do not\nadd speculative hardening beyond what the task needs. A documented rejection is a\nvalid outcome. Otherwise implement the requested work. Stop when no code or test\nchanges are needed.'
TRANSIENT_OUTPUT_PATTERN='"api_error_status"[[:space:]]*:[[:space:]]*(408|425|429|500|502|503|504|522|529)|"(error|type|error_name)"[[:space:]]*:[[:space:]]*"(rate_?limit(_error)?|overloaded(_error)?|api_error|server_error)"|rate[ _-]?limit|temporarily limiting requests|too many requests|overloaded|service unavailable|bad gateway|gateway time-?out|connection (error|reset|refused|closed|timed out)|ECONNRESET|ETIMEDOUT|EAI_AGAIN|stream (disconnected|error)|(internal )?server (error|had an error)|api error[^[:digit:]]{0,8}(408|425|429|500|502|503|504|529)|http[ /]?(408|425|429|500|502|503|504|522|529)|status[ _-]?code[^[:digit:]]{0,4}(408|425|429|500|502|503|504|522|529)|cloudflare[^[:digit:]]{0,40}522|522[^[:alpha:]]{0,40}cloudflare|"(status|error_code)"[[:space:]]*:[[:space:]]*522.*"cloudflare_error"[[:space:]]*:[[:space:]]*true|"cloudflare_error"[[:space:]]*:[[:space:]]*true.*"(status|error_code)"[[:space:]]*:[[:space:]]*522|"(error|type|error_name)"[[:space:]]*:[[:space:]]*"connection_timeout".*"cloudflare_error"[[:space:]]*:[[:space:]]*true|"cloudflare_error"[[:space:]]*:[[:space:]]*true.*"(error|type|error_name)"[[:space:]]*:[[:space:]]*"connection_timeout"|\b529\b'
RETRY_AFTER_PATTERN='"retry[_-]after"[[:space:]]*:[[:space:]]*"?[0-9]+"?|retry-after[[:space:]]*:[[:space:]]*[0-9]+'
readonly TRANSIENT_OUTPUT_PATTERN RETRY_AFTER_PATTERN

usage() {
  cat <<'EOF'
rb-lite: run a small implement/review loop in the current git repository

Usage:
  bin/rb-lite --help
  bin/rb-lite run [options]

Options:
  --task TEXT             Task prompt to append to the implementer prompt.
  --task-file PATH        Read task prompt from PATH.
  --base REF              Review base ref. Default: RB_LITE_BASE or origin/master.
  --max-rounds N          Maximum implement/review rounds. Default: RB_LITE_MAX_ROUNDS or 25.
  --max-noop-rounds N     Stop after N consecutive no-op implementer rounds with
                          reviewer findings. Default: RB_LITE_MAX_NOOP_ROUNDS or 2.
  --max-iters N           Maximum implementer iterations per round. Default: RB_LITE_MAX_ITERS or 25.
  --implement-timeout SECS
                          Timeout in seconds for each implementer iteration;
                          sends SIGTERM, then SIGKILL after a short grace period.
                          Requires a timeout binary on PATH that supports
                          --kill-after (GNU coreutils or uutils). Default:
                          RB_LITE_IMPLEMENT_TIMEOUT or 14400 (4 hours).
  --reviewer-timeout SECS
                          Timeout in seconds for each reviewer command;
                          sends SIGTERM, then SIGKILL after a short grace period.
                          Empty string disables the timeout. Requires a timeout
                          binary on PATH that supports --kill-after (GNU
                          coreutils or uutils). Default:
                          RB_LITE_REVIEWER_TIMEOUT or 1800 (30 minutes).
  --implementer NAME[,NAME...]
                          Implementer preset to use, or comma-separated preset
                          cycle. Each name must be one of claude, codex.
                          Default: RB_LITE_IMPLEMENTER. There is no built-in
                          default; an implementer or implement-cmd is required.
  --implement-cmd CMD     Raw implementer shell command escape hatch. Takes
                          precedence over implementer presets. Default:
                          RB_LITE_IMPLEMENT_CMD.
  --reviewers-file PATH   Reviewer command file. Default: RB_LITE_REVIEWERS_FILE or .rb-lite-reviewers.
  --min-findings-severity LEVEL
                          Minimum reviewer finding severity that triggers another round.
                          One of P0, P1, P2, P3. Default:
                          RB_LITE_MIN_FINDINGS_SEVERITY or P2.
  --run-dir PATH          Store run artifacts in PATH. Default: RB_LITE_RUN_DIR or .rb-lite/runs/<id>.
  --branch NAME           Create and switch to NAME before running.
  -h, --help              Show this help.

Environment:
  RB_LITE_BASE            Default review base.
  RB_LITE_MAX_ROUNDS      Default maximum review rounds.
  RB_LITE_MAX_NOOP_ROUNDS Default consecutive no-op rounds before stopping.
  RB_LITE_MAX_ITERS       Default maximum implementer iterations per round.
  RB_LITE_IMPLEMENT_TIMEOUT
                          Default implementer iteration timeout in seconds.
  RB_LITE_REVIEWER_TIMEOUT
                          Default reviewer command timeout in seconds; empty
                          disables reviewer timeouts.
  RB_LITE_IMPLEMENTER     Default implementer preset or comma-separated preset
                          cycle. Each name must be one of claude, codex.
  RB_LITE_IMPLEMENT_CMD   Shell command run for each implementer iteration.
  RB_LITE_PREV_SESSION    Exported to the implementer with the prior same-round session ID.
  RB_LITE_SESSION_REGEX   Bash ERE for session IDs in implementer stderr; empty disables capture.
  RB_LITE_REVIEWERS_FILE  File with one reviewer shell command per non-comment line.
  RB_LITE_MIN_FINDINGS_SEVERITY
                          Default minimum reviewer finding severity. Default: P2.
  RB_LITE_RUN_DIR         Explicit run artifact directory.
  RB_LITE_API_RETRY_DELAYS
                          Space-separated backoff, in seconds, before retrying an
                          implementer iteration that failed with a TRANSIENT
                          provider error (rate limit / overloaded / 5xx /
                          Cloudflare 522 / network). The last value repeats,
                          unless provider output includes retry_after with a
                          larger delay. Default: "10 30 60".
  RB_LITE_API_MAX_RETRIES Maximum transient-error retries for a single
                          implementer iteration before the round fails. Default:
                          10. Set to 0 to disable retrying.
  RB_LITE_SCRUB_ENV       Space-separated env var names unset before any
                          implementer/reviewer runs, so a claude child driven from
                          inside a Claude Code session starts a fresh session
                          instead of colliding with the parent. Default scrubs the
                          Claude Code session/instance markers (CLAUDECODE,
                          CLAUDE_CODE_SESSION_ID, ...); auth vars are preserved. Set
                          empty to disable.

There is no default implementer. Pass --implementer claude|codex,
--implementer claude,codex, --implement-cmd, or the matching
RB_LITE_IMPLEMENTER/RB_LITE_IMPLEMENT_CMD env var. A comma-separated
implementer list cycles by review round: round 1 uses the first preset, and
after each review round with actionable findings the next round advances to the
next preset, wrapping at the end. The codex preset starts with codex exec using
noninteractive flags, then uses codex exec resume with the same flags on later
iterations in the same round after capturing a session ID from stderr. The
claude preset uses --output-format stream-json --verbose; rb-lite does not
parse implementer stdout. Override RB_LITE_SESSION_REGEX to support non-codex
session ID formats, or set it empty to disable capture. The first capture group
is used, or the full match when no group is present; no match or an empty
capture leaves RB_LITE_PREV_SESSION empty.
Built-in claude calls force CLAUDE_CODE_MAX_OUTPUT_TOKENS=128000.

By default, only P0/P1/P2 reviewer findings trigger another implementer round;
this is a deliberate behavior change, so P3-only output is considered clean.
Use --min-findings-severity P3 or RB_LITE_MIN_FINDINGS_SEVERITY=P3 to preserve
the old strict P3 behavior.

Reviewer commands run concurrently. If no reviewers file exists, rb-lite runs a
three-reviewer panel:
  codex review --base "$BASE"
  set -o pipefail; CLAUDE_CODE_MAX_OUTPUT_TOKENS=128000 claude -p "<P0..P3 review prompt>" --permission-mode acceptEdits --output-format stream-json --verbose --allowedTools "Bash,Edit,Write,Read,Glob,Grep,WebSearch,WebFetch,Task,TaskOutput,TaskStop,Monitor" | jq -er 'if .type == "result" then if ((.is_error // false) or (((.subtype // "") | tostring) | test("error|fail"))) then error(.result // "claude reviewer returned is_error") else (.result // empty) end else empty end'
  npx -y @google/gemini-cli --policy "$RUN_DIR/gemini-policy.toml" --approval-mode yolo -p "<P0..P3 review prompt>"
rb-lite writes "$RUN_DIR/gemini-policy.toml" per run; it grants all-tool access.
codex, claude, and jq must be on PATH. jq extracts the default claude reviewer's
final result event from claude --output-format stream-json and fails if claude
reports is_error or an error/failure subtype. The Gemini reviewer also needs npx
on PATH plus GEMINI_API_KEY or an OAuth login previously stored by gemini-cli.
Without Gemini credentials, the third reviewer just fails and the panel falls
back to codex+claude. Override the panel by writing .rb-lite-reviewers.
The panel succeeds as long as at least one reviewer exits 0; failed reviewers
are noted in their per-reviewer markdown files but do not abort the run.

Implementers and reviewers run with stdin closed. Per-reviewer markdown files
(one per reviewer, review-round-N-K.md) are passed to the implementer so it can
weigh each opinion independently. Reviewer commands must emit findings
(P0/P1/P2/P3 or "No findings.") on stdout. Stderr is treated as tool/transcript
noise and is excluded from the implementer feedback when the reviewer exits 0.
For failed reviewers, the last 20 lines of stderr are appended to that
reviewer's file. Full stderr is always preserved on disk under
reviewer-round-N-K.stderr.

Commands receive PROMPT, BASE, REVIEW_FILES, RUN_DIR, ROUND, ITERATION, and
REVIEWER_INDEX through the environment as applicable. REVIEW_FILES is a
newline-separated list of per-reviewer markdown paths (one file per reviewer,
written as review-round-N-K.md). The implementer is told via PROMPT to read
each one. The legacy REVIEW_FILE env var has been removed; legacy
--implement-cmd wrappers must read REVIEW_FILES instead.

Every run exit and command-line error exit prints a single JSON summary object
as the final stdout line. See README.md for the schema.

Exit codes:
  0   Clean review panel.
  2   Usage error, including invalid flags or missing task files.
  3   Environment/preflight error, including git repo, branch creation, timeout support, or run-dir/log setup.
  10  Implementer loop failed; subprocess failures, timeouts, and max-iters are normalized to 10.
  11  Review panel failed because zero reviewers exited 0.
  12  Max rounds hit before clean review.
  13  Consensus failure after repeated no-op implementer rounds with findings.
  70  Internal rb-lite invariant or unexpected shell failure.
EOF
}

die_with() {
  local code=$1
  shift
  printf '%s: %s\n' "$PROGRAM" "$*" >&2
  exit "$code"
}

die() {
  die_with "$EXIT_USAGE" "$@"
}

implement_cmd_for_preset() {
  local name=$1

  case $name in
    claude)
      printf '%s\n' 'CLAUDE_CODE_MAX_OUTPUT_TOKENS=128000 claude -p "$PROMPT" --permission-mode acceptEdits --output-format stream-json --verbose --allowedTools "Bash,Edit,Write,Read,Glob,Grep,WebSearch,WebFetch,Task,TaskOutput,TaskStop,Monitor"'
      ;;
    codex)
      printf '%s\n' 'if [[ -n ${RB_LITE_PREV_SESSION:-} ]]; then codex exec resume --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check "$RB_LITE_PREV_SESSION" "$PROMPT"; else codex exec --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check "$PROMPT"; fi'
      ;;
    *)
      return 1
      ;;
  esac
}

parse_implementer_preset_list() {
  local value=$1
  local rest part

  if [[ -z $value || $value == ,* || $value == *, || $value == *,,* ]]; then
    return 1
  fi

  rest=$value
  while :; do
    part=${rest%%,*}
    case $part in
      claude|codex)
        printf '%s ' "$part"
        ;;
      *)
        return 1
        ;;
    esac

    [[ $rest == *,* ]] || break
    rest=${rest#*,}
  done
}

log_msg() {
  printf '[%s] %s\n' "$(date -u +'%Y-%m-%dT%H:%M:%SZ')" "$1" | tee -a "$LOG_FILE" >&2
}

is_positive_int() {
  [[ ${1:-} =~ ^[1-9][0-9]*$ ]]
}

json_escape() {
  local s=${1:-}
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  s=${s//$'\n'/\\n}
  s=${s//$'\r'/\\r}
  s=${s//$'\t'/\\t}
  printf '%s' "$s"
}

emit_exit_summary() {
  local rc=$1 now duration run_dir_json implement_timeout_json reviewer_timeout_json status min_severity_json
  trap - ERR
  set +e
  [[ ${SUMMARY_ENABLED:-0} == 1 ]] || return 0

  if [[ -n ${SUMMARY_STATUS:-} ]]; then
    status=$SUMMARY_STATUS
  else
    case $rc in
      "$EXIT_USAGE") status=usage_error ;;
      "$EXIT_ENV") status=env_error ;;
      "$EXIT_IMPLEMENTER") status=implementer_failed ;;
      "$EXIT_REVIEW_PANEL") status=review_panel_failed ;;
      "$EXIT_MAX_ROUNDS") status=max_rounds_hit ;;
      "$EXIT_CONSENSUS") status=consensus_failure ;;
      *) status=internal_error ;;
    esac
  fi

  duration=0
  if [[ -n ${SUMMARY_STARTED_AT:-} ]]; then
    now=$(date -u +%s 2>/dev/null)
    duration=$((now - SUMMARY_STARTED_AT))
    ((duration >= 0)) || duration=0
  fi

  run_dir_json=null
  [[ -z ${RUN_DIR:-} ]] || run_dir_json=\"$(json_escape "$RUN_DIR")\"
  implement_timeout_json=null
  [[ -z ${SUMMARY_IMPLEMENT_TIMEOUT_SECS:-} ]] || implement_timeout_json=$SUMMARY_IMPLEMENT_TIMEOUT_SECS
  reviewer_timeout_json=null
  [[ -z ${SUMMARY_REVIEWER_TIMEOUT_SECS:-} ]] || reviewer_timeout_json=$SUMMARY_REVIEWER_TIMEOUT_SECS

  min_severity_json=$(json_escape "${SUMMARY_MIN_FINDINGS_SEVERITY:-P2}")
  printf '{"run_dir": %s, "exit_code": %s, "status": "%s", "rounds": %s, "implementer_iterations": %s, "noop_rounds_streak": %s, "duration_secs": %s, "config": {"max_rounds": %s, "max_iters": %s, "max_noop_rounds": %s, "min_findings_severity": "%s", "implement_timeout_secs": %s, "reviewer_timeout_secs": %s}}\n' \
    "$run_dir_json" "$rc" "$status" "${SUMMARY_ROUNDS:-0}" "${SUMMARY_IMPLEMENTER_ITERATIONS:-0}" \
    "${SUMMARY_NOOP_ROUNDS_STREAK:-0}" "$duration" "${SUMMARY_MAX_ROUNDS:-25}" \
    "${SUMMARY_MAX_ITERS:-25}" "${SUMMARY_MAX_NOOP_ROUNDS:-2}" "$min_severity_json" "$implement_timeout_json" "$reviewer_timeout_json"
}

handle_signal() {
  local signal_name=$1
  local signal_number=$2
  local pid
  trap - "$signal_name"
  SUMMARY_STATUS=internal_error
  for pid in "${ACTIVE_CHILD_PIDS[@]}"; do
    kill -"$signal_name" "$pid" 2>/dev/null || true
  done
  exit $((128 + signal_number))
}

make_run_dir() {
  local root=$1
  local requested=$2
  local target

  if [[ -n $requested ]]; then
    target=$requested
  else
    target="$root/.rb-lite/runs/$(date -u +'%Y%m%dT%H%M%SZ')-$$"
  fi
  mkdir -p "$target"
  (cd "$target" && pwd -P)
}

filtered_pathspec=(
  .
  ':(exclude).rb-lite'
  ':(exclude).rb-lite/**'
  ':(exclude).ralph-burning'
  ':(exclude).ralph-burning/**'
  ':(exclude).git/ralph-burning-live'
  ':(exclude).git/ralph-burning-live/**'
)

fingerprint_git_state() {
  local root=$1
  local run_dir_abs rel
  local -a pathspec

  pathspec=("${filtered_pathspec[@]}")
  if [[ -n ${RUN_DIR:-} ]]; then
    run_dir_abs=$(cd "$RUN_DIR" 2>/dev/null && pwd -P || true)
    if [[ -n $run_dir_abs && $run_dir_abs == "$root"/* ]]; then
      rel=${run_dir_abs#"$root"/}
      pathspec+=(":(exclude)$rel" ":(exclude)$rel/**")
    fi
  fi

  (
    cd "$root"
    {
      printf 'STATUS\n'
      git status --porcelain=v1 --untracked-files=all -- "${pathspec[@]}" | LC_ALL=C sort
      printf 'INDEX\n'
      git ls-files -s -- "${pathspec[@]}" | LC_ALL=C sort
      printf 'WORKTREE\n'
      git ls-files -z -co --exclude-standard -- "${pathspec[@]}" \
        | LC_ALL=C sort -z \
        | while IFS= read -r -d '' path; do
            printf 'PATH\0%s\0' "$path"
            if [[ -L $path ]]; then
              printf 'TYPE\0SYMLINK\0TARGET\0%s\0' "$(readlink -- "$path")"
            elif [[ -f $path ]]; then
              printf 'TYPE\0FILE\0HASH\0'
              sha256sum -- "$path" | awk '{printf "%s\0", $1}'
            else
              printf 'TYPE\0OTHER\0'
            fi
          done
    } | sha256sum | awk '{print $1}'
  )
}

build_prompt() {
  local task=$1
  shift
  local -a review_paths=("$@")
  local p

  printf '%s\n' "$DEFAULT_PROMPT"
  if [[ -n $task ]]; then
    printf '\nTask:\n%s\n' "$task"
  fi
  if (( ${#review_paths[@]} > 0 )); then
    printf '\nReview files (one per reviewer; read each independently and weigh findings — reviewers may disagree):\n'
    for p in "${review_paths[@]}"; do
      printf '  %s\n' "$p"
    done
    printf 'Address the actionable %s findings across these reviews by fixing real issues or recording a reasoned rejection for false positives or over-specification, then stop when no code or test changes are needed.\n' "${ACTIONABLE_FINDINGS_SEVERITIES:-P0/P1/P2}"
  fi
}

# Heuristic: did an implementer iteration fail because of a TRANSIENT provider
# error (rate limit / overloaded / 5xx / Cloudflare 522 / network blip) rather than a real,
# work-affecting failure? Inspects the captured stdout + stderr. A transient
# error did no work (the git state is unchanged) and clears on its own, so the
# same iteration is worth retrying with backoff; a genuine failure must still
# fail the round fast. Deliberately broad enough to catch both the claude CLI's
# structured `"api_error_status": 429` / `"error": "rate_limit"` and codex/other
# providers' plain-text "rate limit" / "overloaded" / "Too Many Requests" / 5xx
# / Cloudflare 522 / connection-error messages.
implementer_output_file_is_transient() {
  local file=$1
  grep -qiE "$TRANSIENT_OUTPUT_PATTERN" -- "$file" 2>/dev/null
}

implementer_output_line_is_transient() {
  local line=$1
  grep -qiE "$TRANSIENT_OUTPUT_PATTERN" <<<"$line" 2>/dev/null
}

implementer_failure_is_transient() {
  local stdout=$1 stderr=$2
  implementer_output_file_is_transient "$stderr" || implementer_output_file_is_transient "$stdout"
}

# Provider error payloads sometimes include a structured retry_after value. When
# present, use it as a floor over rb-lite's retry schedule.
implementer_retry_after_delay() {
  local stdout=$1 stderr=$2 line match source
  if implementer_output_file_is_transient "$stderr"; then
    source=$stderr
  elif implementer_output_file_is_transient "$stdout"; then
    source=$stdout
  else
    return
  fi

  while IFS= read -r line || [[ -n $line ]]; do
    implementer_output_line_is_transient "$line" || continue
    match=$(grep -Eiom1 "$RETRY_AFTER_PATTERN" <<<"$line" 2>/dev/null || true)
    if [[ $match =~ ([0-9]+) ]]; then
      printf '%s' "${BASH_REMATCH[1]}"
      return
    fi
  done <"$source"
}

# Backoff, in seconds, before the Nth (0-based) transient-error retry. Read from
# RB_LITE_API_RETRY_DELAYS (default "10 30 60"); the last entry repeats for all
# later retries, so the steady state is the final value.
implementer_retry_delay() {
  local attempt=$1 token
  local -a raw schedule
  read -r -a raw <<<"${RB_LITE_API_RETRY_DELAYS-10 30 60}"
  # Keep only non-negative integers — a non-numeric entry would otherwise reach
  # `sleep "$delay"`, fail, and trip the `set -Eeuo pipefail` ERR trap. Fall back
  # to the default schedule when nothing valid remains.
  for token in "${raw[@]}"; do
    if [[ $token =~ ^[0-9]+$ ]]; then
      schedule+=("$token")
    fi
  done
  if (( ${#schedule[@]} == 0 )); then
    schedule=(10 30 60)
  fi
  if (( attempt >= ${#schedule[@]} )); then
    attempt=$(( ${#schedule[@]} - 1 ))
  fi
  printf '%s' "${schedule[attempt]}"
}

run_implementer_loop() {
  local root=$1
  local round=$2
  local max_iters=$3
  local implement_timeout=$4
  local command=$5
  local task=$6
  shift 6
  local -a review_paths=("$@")
  local iter before after prompt stdout stderr rc review_files_env prev_session session_regex line
  local api_retries max_api_retries delay retry_after_delay retry_after_note
  local -a implementer_argv

  if (( ${#review_paths[@]} > 0 )); then
    review_files_env=$(printf '%s\n' "${review_paths[@]}")
  else
    review_files_env=
  fi

  if [[ -n $implement_timeout ]]; then
    # timeout's default mode signals the command process group, covering
    # children spawned by the implementer shell.
    implementer_argv=(timeout --kill-after="$TIMEOUT_KILL_AFTER" "$implement_timeout" bash -c "$command")
  else
    implementer_argv=(bash -c "$command")
  fi

  prev_session=
  session_regex=${RB_LITE_SESSION_REGEX-'session id: ([[:xdigit:]]{8}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{12})'}
  max_api_retries=${RB_LITE_API_MAX_RETRIES:-10}
  [[ $max_api_retries =~ ^[0-9]+$ ]] || max_api_retries=10
  iter=1
  while (( iter <= max_iters )); do
    before=$(fingerprint_git_state "$root")
    prompt=$(build_prompt "$task" "${review_paths[@]}")
    stdout="$RUN_DIR/implementer-round-${round}-iter-${iter}.stdout"
    stderr="$RUN_DIR/implementer-round-${round}-iter-${iter}.stderr"
    log_msg "round $round implementer iteration $iter starting"
    SUMMARY_IMPLEMENTER_ITERATIONS=$((SUMMARY_IMPLEMENTER_ITERATIONS + 1))

    # A transient provider error (rate limit / overloaded / 5xx / network) clears
    # on its own, so retry the SAME iteration with backoff rather than failing the
    # round. The iteration counter does not advance — a retry re-runs the same
    # prompt, exactly as the normal stabilization loop already re-runs the
    # implementer on a changed worktree. A timeout (124), a SIGKILL (137), or any
    # non-transient failure is not a provider blip and falls through to the
    # failure handling below.
    api_retries=0
    while :; do
      (
        cd "$root"
        RB_LITE_PREV_SESSION=$prev_session PROMPT=$prompt REVIEW_FILES=$review_files_env RUN_DIR=$RUN_DIR ROUND=$round ITERATION=$iter "${implementer_argv[@]}" </dev/null
      ) >"$stdout" 2>"$stderr" &
      ACTIVE_CHILD_PIDS=("$!")
      if wait "$!"; then
        rc=0
      else
        rc=$?
      fi
      ACTIVE_CHILD_PIDS=()

      (( rc != 0 )) || break
      (( max_api_retries > 0 )) || break
      (( api_retries < max_api_retries )) || break
      # A timeout (124) or a SIGKILL (137, e.g. `timeout --kill-after` escalating
      # past a process that ignored SIGTERM) is a hang/kill, not a transient API
      # error — never retry it, even if the killed output happened to print a
      # transient marker. 124 is the timeout convention regardless of whether
      # rb-lite set the timeout, so it is excluded unconditionally like 137.
      (( rc != 124 )) || break
      (( rc != 137 )) || break
      implementer_failure_is_transient "$stdout" "$stderr" || break

      delay=$(implementer_retry_delay "$api_retries")
      retry_after_delay=$(implementer_retry_after_delay "$stdout" "$stderr")
      retry_after_note=
      if [[ -n $retry_after_delay ]] && (( retry_after_delay > delay )); then
        delay=$retry_after_delay
        retry_after_note=" (provider retry_after ${retry_after_delay}s)"
      fi
      api_retries=$((api_retries + 1))
      log_msg "round $round implementer iteration $iter hit a transient API error (exit $rc); retry $api_retries/$max_api_retries in ${delay}s${retry_after_note}"
      sleep "$delay"
    done

    prev_session=
    if [[ -n $session_regex ]]; then
      while IFS= read -r line || [[ -n $line ]]; do
        if [[ $line =~ $session_regex ]]; then
          if [[ ${BASH_REMATCH[1]+_} ]]; then
            prev_session=${BASH_REMATCH[1]}
          else
            prev_session=${BASH_REMATCH[0]}
          fi
          break
        fi
      done <"$stderr"
    fi

    if (( rc != 0 )); then
      if [[ -n $implement_timeout && $rc == 124 ]]; then
        log_msg "round $round implementer iteration $iter failed with exit $rc (timed out after ${implement_timeout}s)"
      else
        log_msg "round $round implementer iteration $iter failed with exit $rc"
      fi
      return "$rc"
    fi

    after=$(fingerprint_git_state "$root")
    if [[ $before == "$after" ]]; then
      log_msg "round $round implementer stabilized at iteration $iter"
      return 0
    fi

    log_msg "round $round implementer changed git state at iteration $iter"
    ((iter++))
  done

  log_msg "round $round hit max implementer iterations ($max_iters) before stabilizing"
  return 1
}

load_reviewers() {
  local reviewers_file=$1
  REVIEWERS=()

  if [[ -f $reviewers_file ]]; then
    local line
    while IFS= read -r line || [[ -n $line ]]; do
      [[ -z ${line//[[:space:]]/} ]] && continue
      [[ $line =~ ^[[:space:]]*# ]] && continue
      REVIEWERS+=("$line")
    done <"$reviewers_file"
  fi

  if ((${#REVIEWERS[@]} == 0)); then
    REVIEWERS=(
      'codex review --base "$BASE"'
      'set -o pipefail; CLAUDE_CODE_MAX_OUTPUT_TOKENS=128000 claude -p "Read AGENTS.md if present, then review the changes in this git repository since base ref $BASE. Ignore any changes under .rb-lite/, .ralph-burning/, or .git/ralph-burning-live/ — these are runtime/orchestration state, not code under review. List actionable findings, each on its own line and prefixed with a severity tag: P0 (must-fix correctness/security), P1 (should-fix before merge), P2 (nice-to-have), P3 (nit). If there are no actionable findings, output exactly: No findings. Do not modify any files." --permission-mode acceptEdits --output-format stream-json --verbose --allowedTools "Bash,Edit,Write,Read,Glob,Grep,WebSearch,WebFetch,Task,TaskOutput,TaskStop,Monitor" | jq -er '\''if .type == "result" then if ((.is_error // false) or (((.subtype // "") | tostring) | test("error|fail"))) then error(.result // "claude reviewer returned is_error") else (.result // empty) end else empty end'\'''
      'if [[ -e node_modules/@google/gemini-cli || -L node_modules/@google/gemini-cli || -e node_modules/.bin/gemini || -L node_modules/.bin/gemini ]]; then printf "%s\n" "rb-lite: refusing to run default Gemini reviewer because this repository has a local Gemini CLI package/bin that npx could prefer; customize .rb-lite-reviewers if this is intentional" >&2; exit 1; fi; npx -y @google/gemini-cli --policy "$RUN_DIR/gemini-policy.toml" --approval-mode yolo -p "Read AGENTS.md if present, then review the changes in this git repository since base ref $BASE. Ignore any changes under .rb-lite/, .ralph-burning/, or .git/ralph-burning-live/ — these are runtime/orchestration state, not code under review. List actionable findings, each on its own line and prefixed with a severity tag: P0 (must-fix correctness/security), P1 (should-fix before merge), P2 (nice-to-have), P3 (nit). If there are no actionable findings, output exactly: No findings. Do not modify any files."'
    )
  fi
}

write_review_files() {
  local round=$1
  local count=$2
  local idx stdout stderr rc status path
  REVIEW_FILES_PATHS=()

  for ((idx = 1; idx <= count; idx++)); do
    stdout="$RUN_DIR/reviewer-round-${round}-${idx}.stdout"
    stderr="$RUN_DIR/reviewer-round-${round}-${idx}.stderr"
    rc=${REVIEWER_RCS[$((idx - 1))]:-0}
    if (( rc == 0 )); then
      status="exit 0"
    else
      status="exit $rc — output may be partial"
    fi
    path="$RUN_DIR/review-round-${round}-${idx}.md"
    {
      printf '# Reviewer %s (%s)\n\n' "$idx" "$status"
      if [[ -s $stdout ]]; then
        cat "$stdout"
      else
        printf '(no stdout)\n'
      fi
      if (( rc != 0 )); then
        printf '\n\n## Reviewer %s stderr tail (last 20 lines)\n\n```\n' "$idx"
        if [[ -s $stderr ]]; then
          tail -n 20 "$stderr"
        else
          printf '(empty)\n'
        fi
        printf '```\n'
      fi
    } >"$path"
    if (( rc == 0 )); then
      REVIEW_FILES_PATHS+=("$path")
    fi
  done
}

review_has_findings() {
  local round=$1
  local count=$2
  local idx stdout rc
  for ((idx = 1; idx <= count; idx++)); do
    rc=${REVIEWER_RCS[$((idx - 1))]:-0}
    (( rc == 0 )) || continue
    stdout="$RUN_DIR/reviewer-round-${round}-${idx}.stdout"
    [[ -f $stdout ]] || continue
    if grep -Eq "$FINDINGS_SEVERITY_PATTERN" "$stdout"; then
      return 0
    fi
  done
  return 1
}

run_review_panel() {
  local root=$1
  local round=$2
  local base=$3
  local reviewers_file=$4
  local reviewer_timeout=$5
  local count idx command stdout stderr pid failed succeeded rc
  local -a pids reviewer_argv

  REVIEW_PANEL_RESULT=failed
  REVIEW_PANEL_FAILURE_EXIT=0
  REVIEWER_RCS=()
  load_reviewers "$reviewers_file"
  count=${#REVIEWERS[@]}
  pids=()
  log_msg "round $round review panel starting with $count reviewer(s)"

  for ((idx = 1; idx <= count; idx++)); do
    command=${REVIEWERS[$((idx - 1))]}
    stdout="$RUN_DIR/reviewer-round-${round}-${idx}.stdout"
    stderr="$RUN_DIR/reviewer-round-${round}-${idx}.stderr"
    if [[ -n $reviewer_timeout ]]; then
      reviewer_argv=(timeout --kill-after="$TIMEOUT_KILL_AFTER" "$reviewer_timeout" bash -c "$command")
    else
      reviewer_argv=(bash -c "$command")
    fi
    (
      cd "$root"
      BASE=$base RUN_DIR=$RUN_DIR ROUND=$round REVIEWER_INDEX=$idx "${reviewer_argv[@]}" </dev/null
    ) >"$stdout" 2>"$stderr" &
    pids+=("$!")
  done

  ACTIVE_CHILD_PIDS=("${pids[@]}")
  failed=0
  succeeded=0
  for ((idx = 1; idx <= count; idx++)); do
    pid=${pids[$((idx - 1))]}
    if wait "$pid"; then
      rc=0
      ((succeeded++))
    else
      rc=$?
      failed=$rc
      if [[ -n $reviewer_timeout && $rc == 124 ]]; then
        log_msg "round $round reviewer $idx failed with exit $rc (timed out after ${reviewer_timeout}s)"
      else
        log_msg "round $round reviewer $idx failed with exit $rc"
      fi
    fi
    REVIEWER_RCS+=("$rc")
  done
  ACTIVE_CHILD_PIDS=()

  write_review_files "$round" "$count"
  SUMMARY_ROUNDS=$round

  if (( succeeded == 0 )); then
    log_msg "round $round review panel failed: 0 of $count reviewers succeeded (last exit $failed)"
    REVIEW_PANEL_FAILURE_EXIT=$failed
    return 1
  fi

  if (( failed != 0 )); then
    log_msg "round $round review panel proceeded with partial failures: $succeeded of $count reviewers succeeded (last failure exit $failed)"
  fi

  if review_has_findings "$round" "$count"; then
    log_msg "round $round review panel reported actionable findings (floor $MIN_FINDINGS_SEVERITY)"
    REVIEW_PANEL_RESULT=findings
    return 0
  fi

  log_msg "round $round review panel clean (floor $MIN_FINDINGS_SEVERITY)"
  REVIEW_PANEL_RESULT=clean
  return 0
}

run_command() {
  local base=${RB_LITE_BASE:-origin/master}
  local max_rounds=${RB_LITE_MAX_ROUNDS:-25}
  local max_noop_rounds=${RB_LITE_MAX_NOOP_ROUNDS:-2}
  local max_iters=${RB_LITE_MAX_ITERS:-25}
  local implement_timeout=${RB_LITE_IMPLEMENT_TIMEOUT:-14400}
  local reviewer_timeout=${RB_LITE_REVIEWER_TIMEOUT-1800}
  local implement_cmd=
  local implementer=
  local implementer_source=
  local current_implementer_preset=
  local implementer_preset_words=
  local reviewers_file=${RB_LITE_REVIEWERS_FILE:-.rb-lite-reviewers}
  local min_findings_severity=${RB_LITE_MIN_FINDINGS_SEVERITY:-P2}
  local findings_severity_pattern=
  local findings_severity_digits=
  local actionable_findings_severities=
  local findings_tag_prefix='^[[:space:]]*([-*+][[:space:]]*|[0-9]+[.)][[:space:]]*|#{1,6}[[:space:]]*|"?[Tt][Ii][Tt][Ll][Ee]"?[[:space:]]*:[[:space:]]*"?)?'
  local findings_tag_marker='([`][`]?|[*][*])?'
  local findings_tag_sep='([[:space:]]*[:,.)-]|[[:space:]]*[(])'
  local findings_tag_boundary='([[:space:]]*[:,.)-]|[[:space:]]*[(]|[[:space:]]+|$)'
  local findings_line_tag=
  local findings_paren_tag=
  local requested_run_dir=${RB_LITE_RUN_DIR:-}
  local task=
  local task_file=
  local branch=
  local implement_cmd_set=0
  local implementer_set=0
  local root round round_before round_after noop_round_streak
  local implementer_preset_count=0
  local -a implementer_presets=()
  local -a review_paths=()

  while (($#)); do
    case $1 in
      --task)
        (($# >= 2)) || die "--task requires a value"
        task=$2
        shift 2
        ;;
      --task-file)
        (($# >= 2)) || die "--task-file requires a value"
        task_file=$2
        shift 2
        ;;
      --base)
        (($# >= 2)) || die "--base requires a value"
        base=$2
        shift 2
        ;;
      --max-rounds)
        (($# >= 2)) || die "--max-rounds requires a value"
        max_rounds=$2
        shift 2
        ;;
      --max-noop-rounds)
        (($# >= 2)) || die "--max-noop-rounds requires a value"
        max_noop_rounds=$2
        shift 2
        ;;
      --max-iters)
        (($# >= 2)) || die "--max-iters requires a value"
        max_iters=$2
        shift 2
        ;;
      --implement-timeout)
        (($# >= 2)) || die "--implement-timeout requires a value"
        implement_timeout=$2
        shift 2
        ;;
      --reviewer-timeout)
        (($# >= 2)) || die "--reviewer-timeout requires a value"
        reviewer_timeout=$2
        shift 2
        ;;
      --implementer)
        (($# >= 2)) || die "--implementer requires a value"
        implementer=$2
        implementer_set=1
        shift 2
        ;;
      --implement-cmd)
        (($# >= 2)) || die "--implement-cmd requires a value"
        implement_cmd=$2
        implement_cmd_set=1
        shift 2
        ;;
      --reviewers-file)
        (($# >= 2)) || die "--reviewers-file requires a value"
        reviewers_file=$2
        shift 2
        ;;
      --min-findings-severity)
        (($# >= 2)) || die "--min-findings-severity requires a value"
        min_findings_severity=$2
        shift 2
        ;;
      --run-dir)
        (($# >= 2)) || die "--run-dir requires a value"
        requested_run_dir=$2
        shift 2
        ;;
      --branch)
        (($# >= 2)) || die "--branch requires a value"
        branch=$2
        shift 2
        ;;
      -h|--help)
        SUMMARY_ENABLED=0
        usage
        exit 0
        ;;
      *)
        die "unknown run option: $1"
        ;;
    esac
  done

  is_positive_int "$max_rounds" || die "--max-rounds must be a positive integer"
  is_positive_int "$max_noop_rounds" || die "--max-noop-rounds must be a positive integer"
  is_positive_int "$max_iters" || die "--max-iters must be a positive integer"
  [[ -z $implement_timeout ]] || is_positive_int "$implement_timeout" \
    || die "--implement-timeout must be a positive integer number of seconds"
  [[ -z $reviewer_timeout ]] || is_positive_int "$reviewer_timeout" \
    || die "--reviewer-timeout must be a positive integer number of seconds"
  case $min_findings_severity in
    P0) findings_severity_digits=0; actionable_findings_severities=P0 ;;
    P1) findings_severity_digits=0-1; actionable_findings_severities=P0/P1 ;;
    P2) findings_severity_digits=0-2; actionable_findings_severities=P0/P1/P2 ;;
    P3) findings_severity_digits=0-3; actionable_findings_severities=P0/P1/P2/P3 ;;
    *) die "--min-findings-severity must be one of P0, P1, P2, P3" ;;
  esac
  if (( implement_cmd_set )); then
    [[ -n $implement_cmd ]] \
      || die "--implement-cmd was set to an empty command"
  elif (( implementer_set )); then
    implementer_source=--implementer
    if ! implementer_preset_words=$(parse_implementer_preset_list "$implementer"); then
      die "$implementer_source must be one of claude, codex, or a comma-separated list of those names with no empty elements"
    fi
    read -r -a implementer_presets <<<"$implementer_preset_words"
  elif [[ -n ${RB_LITE_IMPLEMENT_CMD:-} ]]; then
    implement_cmd=$RB_LITE_IMPLEMENT_CMD
  elif [[ -n ${RB_LITE_IMPLEMENTER:-} ]]; then
    implementer_source=RB_LITE_IMPLEMENTER
    if ! implementer_preset_words=$(parse_implementer_preset_list "$RB_LITE_IMPLEMENTER"); then
      die "$implementer_source must be one of claude, codex, or a comma-separated list of those names with no empty elements"
    fi
    read -r -a implementer_presets <<<"$implementer_preset_words"
  else
    die "an implementer is required: pass --implementer claude|codex or --implement-cmd"
  fi
  implementer_preset_count=${#implementer_presets[@]}
  SUMMARY_MAX_ROUNDS=$max_rounds
  SUMMARY_MAX_ITERS=$max_iters
  SUMMARY_MAX_NOOP_ROUNDS=$max_noop_rounds
  SUMMARY_MIN_FINDINGS_SEVERITY=$min_findings_severity
  SUMMARY_IMPLEMENT_TIMEOUT_SECS=$implement_timeout
  SUMMARY_REVIEWER_TIMEOUT_SECS=$reviewer_timeout
  # Line tags cover the canonical reviewer examples in tests; the fallback
  # handles common "Issue 1 (P2): ..." style parenthesized severities.
  findings_line_tag="${findings_tag_prefix}(${findings_tag_marker}\\[P[${findings_severity_digits}]\\]${findings_tag_marker}${findings_tag_boundary}?|${findings_tag_marker}P[${findings_severity_digits}]${findings_tag_sep}${findings_tag_marker}${findings_tag_boundary}?|${findings_tag_marker}P[${findings_severity_digits}]${findings_tag_marker}${findings_tag_boundary})"
  findings_paren_tag='^[[:space:]]*([-*+][[:space:]]*|[0-9]+[.)][[:space:]]*|#{1,6}[[:space:]]*)?([[:alpha:]]+[[:space:]]+[0-9]+[[:space:]]*)?[(]P['"${findings_severity_digits}"'][)]([[:space:]]+|[[:space:]]*[:,.)-]|$)'
  findings_severity_pattern="${findings_line_tag}|${findings_paren_tag}"
  MIN_FINDINGS_SEVERITY=$min_findings_severity
  FINDINGS_SEVERITY_PATTERN=$findings_severity_pattern
  ACTIONABLE_FINDINGS_SEVERITIES=$actionable_findings_severities
  if [[ -n $implement_timeout || -n $reviewer_timeout ]]; then
    local timeout_message
    if [[ -n $implement_timeout && -n $reviewer_timeout ]]; then
      timeout_message="--implement-timeout and --reviewer-timeout require a 'timeout' binary on PATH that supports --kill-after"
    elif [[ -n $implement_timeout ]]; then
      timeout_message="--implement-timeout requires a 'timeout' binary on PATH that supports --kill-after"
    else
      timeout_message="--reviewer-timeout requires a 'timeout' binary on PATH that supports --kill-after"
    fi
    command -v timeout >/dev/null || die_with "$EXIT_ENV" "$timeout_message"
    timeout --kill-after=1s 1s true 2>/dev/null || die_with "$EXIT_ENV" "$timeout_message"
  fi
  [[ -n $task && -n $task_file ]] && die "use either --task or --task-file, not both"
  if [[ -n $task_file ]]; then
    [[ -f $task_file ]] || die "task file not found: $task_file"
    task=$(cat "$task_file")
  fi

  root=$(git rev-parse --show-toplevel 2>/dev/null) || die_with "$EXIT_ENV" "not in a git repository"
  cd "$root" || die_with "$EXIT_ENV" "failed to enter git repository root: $root"
  if [[ -n $branch ]]; then
    git switch -c "$branch" || die_with "$EXIT_ENV" "failed to create and switch to branch: $branch"
  fi

  RUN_DIR=$(make_run_dir "$root" "$requested_run_dir") \
    || die_with "$EXIT_ENV" "failed to create run directory"
  SUMMARY_STARTED_AT=$(date -u +%s)
  LOG_FILE="$RUN_DIR/log.txt"
  : >"$LOG_FILE" || die_with "$EXIT_ENV" "failed to initialize run log: $LOG_FILE"
  cat >"$RUN_DIR/gemini-policy.toml" <<'EOF' \
    || die_with "$EXIT_ENV" "failed to initialize Gemini policy: $RUN_DIR/gemini-policy.toml"
[[rule]]
toolName = "*"
decision = "allow"
priority = 1
EOF
  log_msg "run directory: $RUN_DIR"
  log_msg "base: $base"
  log_msg "max rounds: $max_rounds; max no-op rounds: $max_noop_rounds; max implementer iterations: $max_iters"
  [[ -z $implement_timeout ]] || log_msg "implementer iteration timeout: ${implement_timeout}s"
  [[ -z $reviewer_timeout ]] || log_msg "reviewer timeout: ${reviewer_timeout}s"

  round=1
  noop_round_streak=0
  while (( round <= max_rounds )); do
    if (( implementer_preset_count > 0 )); then
      current_implementer_preset=${implementer_presets[$(((round - 1) % implementer_preset_count))]}
      if ! implement_cmd=$(implement_cmd_for_preset "$current_implementer_preset"); then
        die_with "$EXIT_INTERNAL" "$implementer_source preset parser accepted invalid name: $current_implementer_preset"
      fi
      if (( implementer_preset_count > 1 )); then
        log_msg "round $round implementer preset: $current_implementer_preset"
      fi
    fi
    round_before=$(fingerprint_git_state "$root")
    if ! run_implementer_loop "$root" "$round" "$max_iters" "$implement_timeout" "$implement_cmd" "$task" "${review_paths[@]}"; then
      die_with "$EXIT_IMPLEMENTER" "implementer loop failed; see $RUN_DIR"
    fi
    round_after=$(fingerprint_git_state "$root")
    if [[ $round_before == "$round_after" ]]; then
      ((noop_round_streak += 1))
    else
      noop_round_streak=0
    fi
    SUMMARY_NOOP_ROUNDS_STREAK=$noop_round_streak

    if ! run_review_panel "$root" "$round" "$base" "$reviewers_file" "$reviewer_timeout"; then
      die_with "$EXIT_REVIEW_PANEL" "review panel failed with exit $REVIEW_PANEL_FAILURE_EXIT; see $RUN_DIR"
    fi

    case $REVIEW_PANEL_RESULT in
      clean)
        SUMMARY_STATUS=clean
        printf 'rb-lite clean after %s round(s). Artifacts: %s\n' "$round" "$RUN_DIR"
        exit 0
        ;;
      findings)
        if (( noop_round_streak >= max_noop_rounds )); then
          log_msg "round $round no-op implementer streak is $noop_round_streak (threshold $max_noop_rounds); consensus failure with reviewer findings"
          printf 'rb-lite consensus failure after %s no-op implementer round(s); reviewers still report findings but implementer is not changing state. Artifacts: %s\n' "$noop_round_streak" "$RUN_DIR"
          exit "$EXIT_CONSENSUS"
        fi
        review_paths=("${REVIEW_FILES_PATHS[@]}")
        ((round++))
        ;;
      *)
        die_with "$EXIT_INTERNAL" "review panel ended in unexpected state '$REVIEW_PANEL_RESULT'; see $RUN_DIR"
        ;;
    esac
  done

  die_with "$EXIT_MAX_ROUNDS" "max rounds hit before review panel was clean; see $RUN_DIR"
}

main() {
  if (($# == 0)); then
    usage
    exit 0
  fi

  case $1 in
    run)
      SUMMARY_ENABLED=1
      shift
      run_command "$@"
      ;;
    -h|--help)
      usage
      ;;
    *)
      SUMMARY_ENABLED=1
      die "unknown command: $1"
      ;;
  esac
}

RUN_DIR=
LOG_FILE=
REVIEW_PANEL_RESULT=
REVIEW_PANEL_FAILURE_EXIT=0
MIN_FINDINGS_SEVERITY=
FINDINGS_SEVERITY_PATTERN=
ACTIONABLE_FINDINGS_SEVERITIES=
SUMMARY_ENABLED=0
SUMMARY_STATUS=
SUMMARY_STARTED_AT=
SUMMARY_ROUNDS=0
SUMMARY_IMPLEMENTER_ITERATIONS=0
SUMMARY_NOOP_ROUNDS_STREAK=0
SUMMARY_MAX_ROUNDS=25
SUMMARY_MAX_ITERS=25
SUMMARY_MAX_NOOP_ROUNDS=2
SUMMARY_MIN_FINDINGS_SEVERITY=P2
SUMMARY_IMPLEMENT_TIMEOUT_SECS=14400
SUMMARY_REVIEWER_TIMEOUT_SECS=1800
declare -a ACTIVE_CHILD_PIDS
declare -a REVIEWERS
declare -a REVIEWER_RCS
declare -a REVIEW_FILES_PATHS

trap 'handle_signal HUP 1' HUP
trap 'handle_signal INT 2' INT
trap 'handle_signal QUIT 3' QUIT
trap 'handle_signal TERM 15' TERM
trap 'emit_exit_summary "$?"' EXIT
main "$@"
