#!/usr/bin/env bash
set -Eeuo pipefail

PROGRAM=${0##*/}
IMPLEMENT_TIMEOUT_KILL_AFTER=5s

DEFAULT_PROMPT=$'Read AGENTS.md if present. If a review file is provided, address the findings\nin that review. Otherwise implement the requested work. Stop when no code or\ntest changes are needed.'

usage() {
  cat <<'EOF'
rb-lite: run a small implement/review loop in the current git repository

Usage:
  bin/rb-lite --help
  bin/rb-lite run [options]

Options:
  --task TEXT             Task prompt to append to the implementer prompt.
  --task-file PATH        Read task prompt from PATH.
  --base REF              Review base ref. Default: RB_LITE_BASE or origin/master.
  --max-rounds N          Maximum implement/review rounds. Default: RB_LITE_MAX_ROUNDS or 25.
  --max-iters N           Maximum implementer iterations per round. Default: RB_LITE_MAX_ITERS or 25.
  --implement-timeout SECS
                          Timeout in seconds for each implementer iteration;
                          sends SIGTERM, then SIGKILL after a short grace period.
                          Requires GNU coreutils timeout. Default:
                          RB_LITE_IMPLEMENT_TIMEOUT or 14400 (4 hours).
  --implement-cmd CMD     Implementer shell command. Default: RB_LITE_IMPLEMENT_CMD or
                          codex exec, resuming same-round sessions when available.
  --reviewers-file PATH   Reviewer command file. Default: RB_LITE_REVIEWERS_FILE or .rb-lite-reviewers.
  --min-findings-severity LEVEL
                          Minimum reviewer finding severity that triggers another round.
                          One of P0, P1, P2, P3. Default:
                          RB_LITE_MIN_FINDINGS_SEVERITY or P2.
  --run-dir PATH          Store run artifacts in PATH. Default: RB_LITE_RUN_DIR or .rb-lite/runs/<id>.
  --branch NAME           Create and switch to NAME before running.
  -h, --help              Show this help.

Environment:
  RB_LITE_BASE            Default review base.
  RB_LITE_MAX_ROUNDS      Default maximum review rounds.
  RB_LITE_MAX_ITERS       Default maximum implementer iterations per round.
  RB_LITE_IMPLEMENT_TIMEOUT
                          Default implementer iteration timeout in seconds.
  RB_LITE_IMPLEMENT_CMD   Shell command run for each implementer iteration.
  RB_LITE_PREV_SESSION    Exported to the implementer with the prior same-round session ID.
  RB_LITE_SESSION_REGEX   Bash ERE for session IDs in implementer stderr; empty disables capture.
  RB_LITE_REVIEWERS_FILE  File with one reviewer shell command per non-comment line.
  RB_LITE_MIN_FINDINGS_SEVERITY
                          Default minimum reviewer finding severity. Default: P2.
  RB_LITE_RUN_DIR         Explicit run artifact directory.

The default implementer starts with codex exec using noninteractive flags, then
uses codex exec resume with the same flags on later iterations in the same
round after capturing a session ID from stderr. Override RB_LITE_SESSION_REGEX
to support non-codex session ID formats, or set it empty to disable capture.
The first capture group is used, or the full match when no group is present; no
match or an empty capture leaves RB_LITE_PREV_SESSION empty.

By default, only P0/P1/P2 reviewer findings trigger another implementer round;
this is a deliberate behavior change, so P3-only output is considered clean.
Use --min-findings-severity P3 or RB_LITE_MIN_FINDINGS_SEVERITY=P3 to preserve
the old strict P3 behavior.

Reviewer commands run concurrently. If no reviewers file exists, rb-lite runs a
two-reviewer panel:
  codex review --base "$BASE"
  claude -p "<P0..P3 review prompt>" --permission-mode acceptEdits --allowedTools "Bash,Edit,Write,Read,Glob,Grep,WebSearch,WebFetch,Task,TaskOutput,TaskStop,Monitor"
Both binaries must be on PATH. Override the panel by writing .rb-lite-reviewers.
The panel succeeds as long as at least one reviewer exits 0; failed reviewers
are noted in latest-review.md but do not abort the run.

Reviewers run with stdin closed. Per-reviewer markdown files (one per reviewer,
review-round-N-K.md) are passed to the implementer so it can weigh each
opinion independently. Reviewer commands must emit findings (P0/P1/P2/P3 or
"No findings.") on stdout. Stderr is treated as tool/transcript noise and is
excluded from the implementer feedback when the reviewer exits 0. For failed
reviewers, the last 20 lines of stderr are appended to that reviewer's file.
Full stderr is always preserved on disk under reviewer-round-N-K.stderr.

Commands receive PROMPT, BASE, REVIEW_FILES, RUN_DIR, ROUND, ITERATION, and
REVIEWER_INDEX through the environment as applicable. REVIEW_FILES is a
newline-separated list of per-reviewer markdown paths (one file per reviewer,
written as review-round-N-K.md). The implementer is told via PROMPT to read
each one. The legacy REVIEW_FILE env var has been removed; legacy
--implement-cmd wrappers must read REVIEW_FILES instead.
EOF
}

die() {
  printf '%s: %s\n' "$PROGRAM" "$*" >&2
  exit 1
}

log_msg() {
  printf '[%s] %s\n' "$(date -u +'%Y-%m-%dT%H:%M:%SZ')" "$1" >>"$LOG_FILE"
}

is_positive_int() {
  [[ ${1:-} =~ ^[1-9][0-9]*$ ]]
}

make_run_dir() {
  local root=$1
  local requested=$2
  local target

  if [[ -n $requested ]]; then
    target=$requested
  else
    target="$root/.rb-lite/runs/$(date -u +'%Y%m%dT%H%M%SZ')-$$"
  fi
  mkdir -p "$target"
  (cd "$target" && pwd -P)
}

filtered_pathspec=(
  .
  ':(exclude).rb-lite'
  ':(exclude).rb-lite/**'
  ':(exclude).ralph-burning'
  ':(exclude).ralph-burning/**'
  ':(exclude).git/ralph-burning-live'
  ':(exclude).git/ralph-burning-live/**'
)

fingerprint_git_state() {
  local root=$1
  local run_dir_abs rel
  local -a pathspec

  pathspec=("${filtered_pathspec[@]}")
  if [[ -n ${RUN_DIR:-} ]]; then
    run_dir_abs=$(cd "$RUN_DIR" 2>/dev/null && pwd -P || true)
    if [[ -n $run_dir_abs && $run_dir_abs == "$root"/* ]]; then
      rel=${run_dir_abs#"$root"/}
      pathspec+=(":(exclude)$rel" ":(exclude)$rel/**")
    fi
  fi

  (
    cd "$root"
    {
      printf 'STATUS\n'
      git status --porcelain=v1 --untracked-files=all -- "${pathspec[@]}" | LC_ALL=C sort
      printf 'INDEX\n'
      git ls-files -s -- "${pathspec[@]}" | LC_ALL=C sort
      printf 'WORKTREE\n'
      git ls-files -z -co --exclude-standard -- "${pathspec[@]}" \
        | LC_ALL=C sort -z \
        | while IFS= read -r -d '' path; do
            printf 'PATH\0%s\0' "$path"
            if [[ -L $path ]]; then
              printf 'TYPE\0SYMLINK\0TARGET\0%s\0' "$(readlink -- "$path")"
            elif [[ -f $path ]]; then
              printf 'TYPE\0FILE\0HASH\0'
              sha256sum -- "$path" | awk '{printf "%s\0", $1}'
            else
              printf 'TYPE\0OTHER\0'
            fi
          done
    } | sha256sum | awk '{print $1}'
  )
}

build_prompt() {
  local task=$1
  shift
  local -a review_paths=("$@")
  local p

  printf '%s\n' "$DEFAULT_PROMPT"
  if [[ -n $task ]]; then
    printf '\nTask:\n%s\n' "$task"
  fi
  if (( ${#review_paths[@]} > 0 )); then
    printf '\nReview files (one per reviewer; read each independently and weigh findings — reviewers may disagree):\n'
    for p in "${review_paths[@]}"; do
      printf '  %s\n' "$p"
    done
    printf 'Address the actionable %s findings across these reviews, then stop when no code or test changes are needed.\n' "${ACTIONABLE_FINDINGS_SEVERITIES:-P0/P1/P2}"
  fi
}

run_implementer_loop() {
  local root=$1
  local round=$2
  local max_iters=$3
  local implement_timeout=$4
  local command=$5
  local task=$6
  shift 6
  local -a review_paths=("$@")
  local iter before after prompt stdout stderr rc review_files_env prev_session session_regex line
  local -a implementer_argv

  if (( ${#review_paths[@]} > 0 )); then
    review_files_env=$(printf '%s\n' "${review_paths[@]}")
  else
    review_files_env=
  fi

  if [[ -n $implement_timeout ]]; then
    # GNU timeout's default mode signals the command process group, covering
    # children spawned by the implementer shell.
    implementer_argv=(timeout --kill-after="$IMPLEMENT_TIMEOUT_KILL_AFTER" "$implement_timeout" bash -c "$command")
  else
    implementer_argv=(bash -c "$command")
  fi

  prev_session=
  session_regex=${RB_LITE_SESSION_REGEX-'session id: ([[:xdigit:]]{8}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{12})'}
  iter=1
  while (( iter <= max_iters )); do
    before=$(fingerprint_git_state "$root")
    prompt=$(build_prompt "$task" "${review_paths[@]}")
    stdout="$RUN_DIR/implementer-round-${round}-iter-${iter}.stdout"
    stderr="$RUN_DIR/implementer-round-${round}-iter-${iter}.stderr"
    log_msg "round $round implementer iteration $iter starting"

    if (
      cd "$root"
      RB_LITE_PREV_SESSION=$prev_session PROMPT=$prompt REVIEW_FILES=$review_files_env RUN_DIR=$RUN_DIR ROUND=$round ITERATION=$iter "${implementer_argv[@]}"
    ) >"$stdout" 2>"$stderr"; then
      rc=0
    else
      rc=$?
    fi

    prev_session=
    if [[ -n $session_regex ]]; then
      while IFS= read -r line || [[ -n $line ]]; do
        if [[ $line =~ $session_regex ]]; then
          if [[ ${BASH_REMATCH[1]+_} ]]; then
            prev_session=${BASH_REMATCH[1]}
          else
            prev_session=${BASH_REMATCH[0]}
          fi
          break
        fi
      done <"$stderr"
    fi

    if (( rc != 0 )); then
      if [[ -n $implement_timeout && $rc == 124 ]]; then
        log_msg "round $round implementer iteration $iter failed with exit $rc (timed out after ${implement_timeout}s)"
      else
        log_msg "round $round implementer iteration $iter failed with exit $rc"
      fi
      return "$rc"
    fi

    after=$(fingerprint_git_state "$root")
    if [[ $before == "$after" ]]; then
      log_msg "round $round implementer stabilized at iteration $iter"
      return 0
    fi

    log_msg "round $round implementer changed git state at iteration $iter"
    ((iter++))
  done

  log_msg "round $round hit max implementer iterations ($max_iters) before stabilizing"
  return 1
}

load_reviewers() {
  local reviewers_file=$1
  REVIEWERS=()

  if [[ -f $reviewers_file ]]; then
    local line
    while IFS= read -r line || [[ -n $line ]]; do
      [[ -z ${line//[[:space:]]/} ]] && continue
      [[ $line =~ ^[[:space:]]*# ]] && continue
      REVIEWERS+=("$line")
    done <"$reviewers_file"
  fi

  if ((${#REVIEWERS[@]} == 0)); then
    REVIEWERS=(
      'codex review --base "$BASE"'
      'claude -p "Read AGENTS.md if present, then review the changes in this git repository since base ref $BASE. Ignore any changes under .rb-lite/, .ralph-burning/, or .git/ralph-burning-live/ — these are runtime/orchestration state, not code under review. List actionable findings, each on its own line and prefixed with a severity tag: P0 (must-fix correctness/security), P1 (should-fix before merge), P2 (nice-to-have), P3 (nit). If there are no actionable findings, output exactly: No findings. Do not modify any files." --permission-mode acceptEdits --allowedTools "Bash,Edit,Write,Read,Glob,Grep,WebSearch,WebFetch,Task,TaskOutput,TaskStop,Monitor"'
    )
  fi
}

write_review_files() {
  local round=$1
  local count=$2
  local idx stdout stderr rc status path
  REVIEW_FILES_PATHS=()

  for ((idx = 1; idx <= count; idx++)); do
    stdout="$RUN_DIR/reviewer-round-${round}-${idx}.stdout"
    stderr="$RUN_DIR/reviewer-round-${round}-${idx}.stderr"
    rc=${REVIEWER_RCS[$((idx - 1))]:-0}
    if (( rc == 0 )); then
      status="exit 0"
    else
      status="exit $rc — output may be partial"
    fi
    path="$RUN_DIR/review-round-${round}-${idx}.md"
    {
      printf '# Reviewer %s (%s)\n\n' "$idx" "$status"
      if [[ -s $stdout ]]; then
        cat "$stdout"
      else
        printf '(no stdout)\n'
      fi
      if (( rc != 0 )); then
        printf '\n\n## Reviewer %s stderr tail (last 20 lines)\n\n```\n' "$idx"
        if [[ -s $stderr ]]; then
          tail -n 20 "$stderr"
        else
          printf '(empty)\n'
        fi
        printf '```\n'
      fi
    } >"$path"
    if (( rc == 0 )); then
      REVIEW_FILES_PATHS+=("$path")
    fi
  done
}

review_has_findings() {
  local round=$1
  local count=$2
  local idx stdout rc
  for ((idx = 1; idx <= count; idx++)); do
    rc=${REVIEWER_RCS[$((idx - 1))]:-0}
    (( rc == 0 )) || continue
    stdout="$RUN_DIR/reviewer-round-${round}-${idx}.stdout"
    [[ -f $stdout ]] || continue
    if grep -Eq "$FINDINGS_SEVERITY_PATTERN" "$stdout"; then
      return 0
    fi
  done
  return 1
}

run_review_panel() {
  local root=$1
  local round=$2
  local base=$3
  local reviewers_file=$4
  local count idx command stdout stderr pid failed succeeded rc
  local -a pids

  REVIEW_PANEL_RESULT=failed
  REVIEW_PANEL_FAILURE_EXIT=0
  REVIEWER_RCS=()
  load_reviewers "$reviewers_file"
  count=${#REVIEWERS[@]}
  pids=()
  log_msg "round $round review panel starting with $count reviewer(s)"

  for ((idx = 1; idx <= count; idx++)); do
    command=${REVIEWERS[$((idx - 1))]}
    stdout="$RUN_DIR/reviewer-round-${round}-${idx}.stdout"
    stderr="$RUN_DIR/reviewer-round-${round}-${idx}.stderr"
    (
      cd "$root"
      BASE=$base RUN_DIR=$RUN_DIR ROUND=$round REVIEWER_INDEX=$idx bash -c "$command" </dev/null
    ) >"$stdout" 2>"$stderr" &
    pids+=("$!")
  done

  failed=0
  succeeded=0
  for pid in "${pids[@]}"; do
    if wait "$pid"; then
      rc=0
      ((succeeded++))
    else
      rc=$?
      failed=$rc
    fi
    REVIEWER_RCS+=("$rc")
  done

  write_review_files "$round" "$count"

  if (( succeeded == 0 )); then
    log_msg "round $round review panel failed: 0 of $count reviewers succeeded (last exit $failed)"
    REVIEW_PANEL_FAILURE_EXIT=$failed
    return 1
  fi

  if (( failed != 0 )); then
    log_msg "round $round review panel proceeded with partial failures: $succeeded of $count reviewers succeeded (last failure exit $failed)"
  fi

  if review_has_findings "$round" "$count"; then
    log_msg "round $round review panel reported actionable findings (floor $MIN_FINDINGS_SEVERITY)"
    REVIEW_PANEL_RESULT=findings
    return 0
  fi

  log_msg "round $round review panel clean (floor $MIN_FINDINGS_SEVERITY)"
  REVIEW_PANEL_RESULT=clean
  return 0
}

run_command() {
  local base=${RB_LITE_BASE:-origin/master}
  local max_rounds=${RB_LITE_MAX_ROUNDS:-25}
  local max_iters=${RB_LITE_MAX_ITERS:-25}
  local implement_timeout=${RB_LITE_IMPLEMENT_TIMEOUT:-14400}
  local implement_cmd=${RB_LITE_IMPLEMENT_CMD:-'if [[ -n ${RB_LITE_PREV_SESSION:-} ]]; then codex exec resume --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check "$RB_LITE_PREV_SESSION" "$PROMPT"; else codex exec --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check "$PROMPT"; fi'}
  local reviewers_file=${RB_LITE_REVIEWERS_FILE:-.rb-lite-reviewers}
  local min_findings_severity=${RB_LITE_MIN_FINDINGS_SEVERITY:-P2}
  local findings_severity_pattern=
  local findings_severity_digits=
  local actionable_findings_severities=
  local findings_tag_prefix='^[[:space:]]*([-*+][[:space:]]*|[0-9]+[.)][[:space:]]*|#{1,6}[[:space:]]*|"?[Tt][Ii][Tt][Ll][Ee]"?[[:space:]]*:[[:space:]]*"?)?'
  local findings_tag_marker='([`][`]?|[*][*])?'
  local findings_tag_sep='([[:space:]]*[:,.)-]|[[:space:]]*[(])'
  local findings_tag_boundary='([[:space:]]*[:,.)-]|[[:space:]]*[(]|[[:space:]]+|$)'
  local findings_line_tag=
  local findings_paren_tag=
  local requested_run_dir=${RB_LITE_RUN_DIR:-}
  local task=
  local task_file=
  local branch=
  local root round rc
  local -a review_paths=()

  while (($#)); do
    case $1 in
      --task)
        (($# >= 2)) || die "--task requires a value"
        task=$2
        shift 2
        ;;
      --task-file)
        (($# >= 2)) || die "--task-file requires a value"
        task_file=$2
        shift 2
        ;;
      --base)
        (($# >= 2)) || die "--base requires a value"
        base=$2
        shift 2
        ;;
      --max-rounds)
        (($# >= 2)) || die "--max-rounds requires a value"
        max_rounds=$2
        shift 2
        ;;
      --max-iters)
        (($# >= 2)) || die "--max-iters requires a value"
        max_iters=$2
        shift 2
        ;;
      --implement-timeout)
        (($# >= 2)) || die "--implement-timeout requires a value"
        implement_timeout=$2
        shift 2
        ;;
      --implement-cmd)
        (($# >= 2)) || die "--implement-cmd requires a value"
        implement_cmd=$2
        shift 2
        ;;
      --reviewers-file)
        (($# >= 2)) || die "--reviewers-file requires a value"
        reviewers_file=$2
        shift 2
        ;;
      --min-findings-severity)
        (($# >= 2)) || die "--min-findings-severity requires a value"
        min_findings_severity=$2
        shift 2
        ;;
      --run-dir)
        (($# >= 2)) || die "--run-dir requires a value"
        requested_run_dir=$2
        shift 2
        ;;
      --branch)
        (($# >= 2)) || die "--branch requires a value"
        branch=$2
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown run option: $1"
        ;;
    esac
  done

  is_positive_int "$max_rounds" || die "--max-rounds must be a positive integer"
  is_positive_int "$max_iters" || die "--max-iters must be a positive integer"
  [[ -z $implement_timeout ]] || is_positive_int "$implement_timeout" \
    || die "--implement-timeout must be a positive integer number of seconds"
  case $min_findings_severity in
    P0) findings_severity_digits=0; actionable_findings_severities=P0 ;;
    P1) findings_severity_digits=0-1; actionable_findings_severities=P0/P1 ;;
    P2) findings_severity_digits=0-2; actionable_findings_severities=P0/P1/P2 ;;
    P3) findings_severity_digits=0-3; actionable_findings_severities=P0/P1/P2/P3 ;;
    *) die "--min-findings-severity must be one of P0, P1, P2, P3" ;;
  esac
  # Line tags cover the canonical reviewer examples in tests; the fallback
  # handles common "Issue 1 (P2): ..." style parenthesized severities.
  findings_line_tag="${findings_tag_prefix}(${findings_tag_marker}\\[P[${findings_severity_digits}]\\]${findings_tag_marker}${findings_tag_boundary}?|${findings_tag_marker}P[${findings_severity_digits}]${findings_tag_sep}${findings_tag_marker}${findings_tag_boundary}?|${findings_tag_marker}P[${findings_severity_digits}]${findings_tag_marker}${findings_tag_boundary})"
  findings_paren_tag='^[[:space:]]*([-*+][[:space:]]*|[0-9]+[.)][[:space:]]*|#{1,6}[[:space:]]*)?([[:alpha:]]+[[:space:]]+[0-9]+[[:space:]]*)?[(]P['"${findings_severity_digits}"'][)]([[:space:]]+|[[:space:]]*[:,.)-]|$)'
  findings_severity_pattern="${findings_line_tag}|${findings_paren_tag}"
  MIN_FINDINGS_SEVERITY=$min_findings_severity
  FINDINGS_SEVERITY_PATTERN=$findings_severity_pattern
  ACTIONABLE_FINDINGS_SEVERITIES=$actionable_findings_severities
  if [[ -n $implement_timeout ]]; then
    command -v timeout >/dev/null || die "--implement-timeout requires GNU coreutils timeout"
    timeout --version 2>/dev/null | grep -q 'GNU coreutils' \
      || die "--implement-timeout requires GNU coreutils timeout"
  fi
  [[ -n $task && -n $task_file ]] && die "use either --task or --task-file, not both"
  if [[ -n $task_file ]]; then
    [[ -f $task_file ]] || die "task file not found: $task_file"
    task=$(cat "$task_file")
  fi

  root=$(git rev-parse --show-toplevel 2>/dev/null) || die "not in a git repository"
  cd "$root"
  if [[ -n $branch ]]; then
    git switch -c "$branch"
  fi

  RUN_DIR=$(make_run_dir "$root" "$requested_run_dir")
  LOG_FILE="$RUN_DIR/log.txt"
  : >"$LOG_FILE"
  log_msg "run directory: $RUN_DIR"
  log_msg "base: $base"
  log_msg "max rounds: $max_rounds; max implementer iterations: $max_iters"
  [[ -z $implement_timeout ]] || log_msg "implementer iteration timeout: ${implement_timeout}s"

  round=1
  while (( round <= max_rounds )); do
    if ! run_implementer_loop "$root" "$round" "$max_iters" "$implement_timeout" "$implement_cmd" "$task" "${review_paths[@]}"; then
      die "implementer loop failed; see $RUN_DIR"
    fi

    if ! run_review_panel "$root" "$round" "$base" "$reviewers_file"; then
      die "review panel failed with exit $REVIEW_PANEL_FAILURE_EXIT; see $RUN_DIR"
    fi

    case $REVIEW_PANEL_RESULT in
      clean)
        printf 'rb-lite clean after %s round(s). Artifacts: %s\n' "$round" "$RUN_DIR"
        exit 0
        ;;
      findings)
        review_paths=("${REVIEW_FILES_PATHS[@]}")
        ((round++))
        ;;
      *)
        die "review panel ended in unexpected state '$REVIEW_PANEL_RESULT'; see $RUN_DIR"
        ;;
    esac
  done

  die "max rounds hit before review panel was clean; see $RUN_DIR"
}

main() {
  if (($# == 0)); then
    usage
    exit 0
  fi

  case $1 in
    run)
      shift
      run_command "$@"
      ;;
    -h|--help)
      usage
      ;;
    *)
      die "unknown command: $1"
      ;;
  esac
}

RUN_DIR=
LOG_FILE=
REVIEW_PANEL_RESULT=
REVIEW_PANEL_FAILURE_EXIT=0
MIN_FINDINGS_SEVERITY=
FINDINGS_SEVERITY_PATTERN=
ACTIONABLE_FINDINGS_SEVERITIES=
declare -a REVIEWERS
declare -a REVIEWER_RCS
declare -a REVIEW_FILES_PATHS

main "$@"
